<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widgetRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg_compact"
    android:gravity="center_vertical"
    android:orientation="vertical">

    <TextView
        android:id="@+id/widgetTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:includeFontPadding="false"
        android:singleLine="true"
        android:text="今日步数"
        android:textColor="#5F716A"
        android:textSize="10sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/widgetSteps"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="sans-serif-medium"
            android:includeFontPadding="false"
            android:singleLine="true"
            android:text="0"
            android:textColor="@color/widget_text_dark"
            android:textSize="22sp" />

        <TextView
            android:id="@+id/widgetPercent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:includeFontPadding="false"
            android:singleLine="true"
            android:text="0%"
            android:textColor="@color/brand_green"
            android:textSize="12sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/widgetDistance"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="1dp"
        android:includeFontPadding="false"
        android:singleLine="true"
        android:text="0.0 km"
        android:textColor="#6F716F"
        android:textSize="11sp" />

    <ProgressBar
        android:id="@+id/widgetProgress"
        style="@android:style/Widget.ProgressBar.Horizontal"
        android:layout_width="match_parent"
        android:layout_height="7dp"
        android:layout_marginTop="5dp"
        android:max="100"
        android:progress="0"
        android:progressDrawable="@drawable/widget_progress_drawable" />
</LinearLayout>
